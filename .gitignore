# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
dist/
build/

# Virtualenvs (no trailing slash on .venv so a worktree's `.venv` symlink is ignored too)
.venv
venv/
env/

# Local config / secrets
.env
.env.local
secrets/

# CLI conversation dumps (/save)
debug/

# Claude Code worktrees / local state — but track the project-level audit skills
# (devchangelog / architecture / verification) so teammates + worktrees inherit them.
.claude/*
!.claude/skills/
.worktreeinclude

# Local app data (memory store, reminders, etc.)
data/
downloads/

# Doc-base source PDFs: build-time input to scripts/split_doc_base.py only (the
# committed split output under doc_base/<volume>/ is what the app reads). ~110 MB
# of originals bloated clones for no runtime benefit — keep them local, unshipped.
doc_base/original/

# Project-local toolchains / binaries
.local/

# Local code-audit artifacts
docs/code_audit_panel.html

# Editor / OS
.DS_Store
.idea/
.vscode/

# Temporary files
tmp/

# "Chain of Focuses" files
cof.md

# Claude tasks
claude_tasks/
